# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to GitHub

# Supabase — https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Flutterwave — https://dashboard.flutterwave.com → Settings → API
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=YOUR_FLW_PUBLIC_KEY
FLUTTERWAVE_SECRET_KEY=YOUR_FLW_SECRET_KEY

# Paystack — https://dashboard.paystack.com → Settings → API Keys
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
